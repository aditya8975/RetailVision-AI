# Leave unset to use local SQLite (zero setup). Docker Compose sets this
# automatically to point at the Postgres container.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/product_intelligence

# Model overrides (defaults shown)
YOLO_MODEL=yolov8n.pt
CLIP_MODEL=openai/clip-vit-base-patch32
CAPTION_MODEL=Salesforce/blip-image-captioning-base

# Set to "true" to force CPU inference even if a GPU is available
FORCE_CPU=false
